{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "system",
  "keybinds": {
    "editor_open": "<leader>ctrl+e",
    "status_view": "<leader>ctrl+s",
    "session_list": "<leader>s",
    "session_child_first": "<leader>ctrl+a",
    "session_child_cycle": "ctrl+n",
    "session_child_cycle_reverse": "ctrl+p",
    "session_parent": "ctrl+b",
    "command_list": "<leader>ctrl+c",
    "input_move_up": "ctrl+p",
    "input_move_down": "ctrl+n",
    "history_previous": "alt+p",
    "history_next": "alt+n"
  }
}
